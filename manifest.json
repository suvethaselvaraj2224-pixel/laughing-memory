{
  "manifest_version": 3,
  "name": "mailbrief",
  "version": "1.0",
  "description": "AI-powered Gmail email summaries in one click",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": [
  "https://mail.google.com/*",
  "https://your-deployed-server.com/*"
],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ]
}